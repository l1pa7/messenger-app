# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_USER=messenger
DB_PASSWORD=ЗАМЕНИ_НА_НАДЁЖНЫЙ_ПАРОЛЬ
DB_NAME=messenger

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=ЗАМЕНИ_НА_REDIS_ПАРОЛЬ

# ─── MinIO (хранилище файлов) ─────────────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=ЗАМЕНИ_НА_MINIO_ПАРОЛЬ
MINIO_BUCKET=messenger-files

# ─── JWT — access token signing key ──────────────────────────────────────────
# Генерировать: openssl rand -hex 32
JWT_SECRET=ЗАМЕНИ_НА_ДЛИННЫЙ_СЛУЧАЙНЫЙ_КЛЮЧ

# ─── AES-256-GCM — ключ шифрования сообщений в PostgreSQL ───────────────────
# Server-side шифрование: даже при утечке БД — ciphertext бесполезен без этого ключа
# Генерировать: openssl rand -hex 32
# ХРАНИТЬ ОТДЕЛЬНО от бэкапов БД!
MESSAGE_ENC_KEY=ЗАМЕНИ_НА_32_БАЙТА_СЛУЧАЙНЫХ

# ─── CORS — допустимые источники (через запятую) ─────────────────────────────
# В production укажи свой домен. "*" — НЕЛЬЗЯ!
ALLOWED_ORIGINS=http://localhost,https://твой-домен.com

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Получить после: cloudflared tunnel create messenger
CF_TUNNEL_TOKEN=
