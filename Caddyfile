{
    admin off
}

# sslip.io превращает IP в домен бесплатно и без регистрации.
# Caddy автоматически получает настоящий Let's Encrypt TLS сертификат
# и сам редиректит весь HTTP трафик на HTTPS.
95.139.86.107.sslip.io {
    handle /ws {
        reverse_proxy backend:8080 {
            header_up Connection "Upgrade"
            header_up Upgrade "websocket"
        }
    }
    handle /api/* {
        reverse_proxy backend:8080
    }
    handle /health {
        reverse_proxy backend:8080
    }
    handle {
        respond "Messenger API" 200
    }
}
